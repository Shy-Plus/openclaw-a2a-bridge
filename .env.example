# ═══════════════════════════════════════════════════════════
#  A2A Bridge Configuration
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ─── Required ─────────────────────────────────────────────
# Gateway auth token (from ~/.openclaw/openclaw.json)
# If not set, the bridge will try to read from openclaw.json automatically
A2A_GATEWAY_TOKEN=

# ─── Local Agent (this machine) ──────────────────────────
# Tailscale IP or hostname of this machine
A2A_LOCAL_HOST=0.0.0.0
A2A_LOCAL_PORT=9100
A2A_LOCAL_API=http://localhost:18789/v1/responses

# Public URL advertised in the Agent Card
# Should be reachable by other agents (e.g., Tailscale IP)
A2A_PUBLIC_URL=http://YOUR_TAILSCALE_IP:9100

# ─── Remote Agent (peer machine) ─────────────────────────
# Only needed for multi-agent setups
A2A_REMOTE_HOST=
A2A_REMOTE_PORT=9100
A2A_REMOTE_API=
A2A_REMOTE_PUBLIC_URL=

# ─── Agent Card ──────────────────────────────────────────
# Path to your agent card JSON (relative or absolute)
A2A_AGENT_CARD=cards/agent_card.json

# ─── Model ───────────────────────────────────────────────
# Model name passed to OpenResponses API
A2A_MODEL=openclaw:main

# ─── Python ──────────────────────────────────────────────
# Python interpreter path (for scripts)
A2A_PYTHON=python3

# ─── Logging ─────────────────────────────────────────────
A2A_TRAFFIC_LOG=~/.openclaw/logs/a2a-traffic.log
